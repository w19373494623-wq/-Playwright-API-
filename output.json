    "/api/ugc/superTopic/list": {
      "get": {
        "tags": ["内容模块"],
        "summary": "获取超级话题列表",
        "description": "用户进入话题广场时调用，获取当前平台所有超级话题的列表数据，包含话题名称、封面图、参与人数等信息，用于前端话题广场展示。",
        "parameters": [
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "description": "分页游标，首次请求传空，后续翻页传入上次返回的游标值",
            "schema": { "type": "string" }
          },
          {
            "name": "size",
            "in": "query",
            "required": false,
            "description": "每页返回数量，默认 10，最大 50",
            "schema": { "type": "integer", "default": 10 }
          }
        ],
        "responses": {
          "200": {
            "description": "成功返回超级话题列表",
            "content": {
              "application/json": {
                "example": {
                  "code": 200,
                  "message": "操作成功",
                  "data": {
                    "list": [
                      {
                        "topicId": "topic_6a0a94fa81e5e769b8f0a7e6",
                        "name": "摄影爱好者",
                        "coverUrl": "https://cdn.guadd.fun/cover/xxx.jpg",
                        "participantCount": 12580,
                        "contentCount": 36420
                      }
                    ],
                    "cursor": "next_page_cursor_value",
                    "hasMore": true
                  }
                }
              }
            }
          }
        }
      }
    },
