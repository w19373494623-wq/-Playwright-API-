    "/api/ugc/createUgc": {
      "post": {
        "tags": ["内容模块"],
        "summary": "发布 UGC 内容",
        "description": "用户编辑完成图文或视频内容后调用，将内容提交到服务器。支持文字、图片、视频等多种内容类型。提交成功后返回内容 ID 供后续操作使用。",
        "parameters": [],
        "requestBody": {
          "description": "发布内容请求体，包含内容类型、标题、正文和媒体文件信息",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "contentType": {
                    "type": "string",
                    "description": "内容类型：text（纯文字）、image（图片）、video（视频）"
                  },
                  "title": {
                    "type": "string",
                    "description": "内容标题，不超过 100 字"
                  },
                  "content": {
                    "type": "string",
                    "description": "内容正文，支持纯文本或富文本格式"
                  },
                  "mediaIds": {
                    "type": "array",
                    "description": "已上传的媒体文件 ID 列表，通过上传接口获取",
                    "items": { "type": "string" }
                  },
                  "topicId": {
                    "type": "string",
                    "description": "关联的话题 ID，可选，发布到指定话题下"
                  },
                  "visibility": {
                    "type": "string",
                    "description": "可见性设置：public（公开）、private（仅自己可见）、followers（仅粉丝可见）",
                    "default": "public"
                  }
                },
                "required": ["contentType", "content"]
              },
              "example": {
                "contentType": "video",
                "title": "我的第一条 UGC 视频",
                "content": "这是视频的描述文字",
                "mediaIds": ["media_001", "media_002"],
                "topicId": "topic_6a0a94fa81e5e769b8f0a7e6",
                "visibility": "public"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "发布成功，返回新创建的内容 ID",
            "content": {
              "application/json": {
                "example": {
                  "code": 200,
                  "message": "发布成功",
                  "data": {
                    "ugcId": "ugc_new_001",
                    "publishTime": "2026-07-01T14:30:00Z",
                    "status": "published"
                  }
                }
              }
            }
          },
          "400": {
            "description": "请求参数校验失败，如缺少必填字段、内容超长等",
            "content": {
              "application/json": {
                "example": {
                  "code": 400,
                  "message": "内容正文不能为空",
                  "data": null
                }
              }
            }
          }
        }
      }
    },
    "/api/community/getUploadPresignedURL": {
      "post": {
        "tags": ["社区模块"],
        "summary": "获取上传预签名地址",
        "description": "用户上传图片或视频前调用，服务端返回一个预签名的上传 URL，客户端直接向该 URL 上传文件。支持图片、视频、音频等媒体类型。",
        "parameters": [],
        "requestBody": {
          "description": "申请上传凭证，指定文件名、大小和类型",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "fileName": {
                    "type": "string",
                    "description": "原始文件名，包含扩展名，用于服务端判断文件类型"
                  },
                  "fileSize": {
                    "type": "integer",
                    "description": "文件大小，单位字节，用于校验上传限额"
                  },
                  "fileType": {
                    "type": "string",
                    "description": "文件 MIME 类型，如 image/jpeg、video/mp4"
                  },
                  "businessType": {
                    "type": "string",
                    "description": "业务类型：ugc_cover（内容封面）、ugc_media（内容媒体）、avatar（头像）"
                  }
                },
                "required": ["fileName", "fileSize", "fileType", "businessType"]
              },
              "example": {
                "fileName": "my_video.mp4",
                "fileSize": 52428800,
                "fileType": "video/mp4",
                "businessType": "ugc_media"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功返回预签名上传地址和文件访问标识",
            "content": {
              "application/json": {
                "example": {
                  "code": 200,
                  "message": "操作成功",
                  "data": {
                    "uploadUrl": "https://cdn-bucket.guadd.fun/xxx-yyy?sign=abc123",
                    "mediaId": "media_001",
                    "expireIn": 3600,
                    "cdnDomain": "https://cdn.guadd.fun"
                  }
                }
              }
            }
          }
        }
      }
    },
